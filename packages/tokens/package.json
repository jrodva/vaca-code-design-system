{
  "name": "@react_native_design_system/tokens",
  "version": "0.0.1",
  "description": "Design tokens for the React Native Design System",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
